# Instituto IPI — variáveis de ambiente
# Copie para .env e preencha com valores reais.
#
# Produção (valores ficam no Infisical, projeto "institutoipi"):
#   APP_DOMAIN=institutoipi.org
#   PAYLOAD_PUBLIC_URL=https://institutoipi.org
#   MINIO_ENDPOINT=minio              # MinIO compartilhado do servidor
#   MINIO_PUBLIC_URL=https://s3-1.luanfernandes.dev
#   MINIO_BUCKET=institutoipi-media
#   MINIO_ROOT_USER/PASSWORD = usuário restrito ao bucket institutoipi-media

# --- Postgres ---
POSTGRES_DB=institutoipi
POSTGRES_USER=institutoipi
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# --- Payload / Next.js ---
CMS_PORT=3000
PAYLOAD_SECRET=troque-por-uma-string-longa-e-aleatoria
DATABASE_URL=postgresql://institutoipi:changeme@localhost:5432/institutoipi
PAYLOAD_PUBLIC_URL=http://localhost:3000

# SITE_URL: origem pública do site (CORS/CSRF); default https://institutoipi.org
SITE_URL=https://institutoipi.org

# --- Mailpit (dev) ---
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# --- Email (SMTP) ---
EMAIL_FROM=contato@institutoipi.org
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USER=dev
EMAIL_SMTP_PASSWORD=dev
EMAIL_SMTP_SECURE=false
LEAD_NOTIFY_TO=contato@institutoipi.org

# --- MinIO (armazenamento S3-compatible) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=institutoipi-media
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000
