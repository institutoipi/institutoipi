# ============================================================================
# Instituto IPI — variáveis de ambiente
#
# DEV LOCAL:  cp .env.example .env  → os valores abaixo já funcionam com o
#             docker-compose (Postgres + MinIO + Mailpit). Não precisa editar.
#
# PRODUÇÃO:   use os MESMOS nomes com os valores dos serviços gerenciados
#             (Neon / UploadThing / Resend). Ver a seção PRODUÇÃO no fim e o README.
# ============================================================================

# --- Payload / Next.js ---
PAYLOAD_SECRET=troque-por-uma-string-longa-e-aleatoria   # prod: openssl rand -hex 32
PAYLOAD_PUBLIC_URL=http://localhost:3000
SITE_URL=http://localhost:3000

# --- Postgres (docker-compose) ---
DATABASE_URL=postgresql://institutoipi:institutoipi@localhost:5432/institutoipi

# --- Mídia: MinIO local, S3-compatible (docker-compose) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=institutoipi-media
MINIO_PUBLIC_URL=http://localhost:9000

# --- Email: Mailpit local (docker-compose) — UI em http://localhost:8025 ---
EMAIL_FROM=contato@institutoipi.org
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USER=dev
EMAIL_SMTP_PASSWORD=dev
EMAIL_SMTP_SECURE=false
LEAD_NOTIFY_TO=contato@institutoipi.org
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# ============================================================================
# PRODUÇÃO (self-hosted) — fica em /opt/institutoipi/.env no servidor.
# O docker-compose.prod.yml deriva a DATABASE_URL interna e o MINIO_ENDPOINT.
#
#   PAYLOAD_SECRET      openssl rand -hex 32
#   PAYLOAD_PUBLIC_URL  https://SEU-DOMINIO
#   SITE_URL            https://SEU-DOMINIO
#   APP_DOMAIN          SEU-DOMINIO            (o Caddy emite o TLS)
#
#   POSTGRES_DB=institutoipi  POSTGRES_USER=institutoipi  POSTGRES_PASSWORD=<forte>
#   MINIO_ROOT_USER=<user>    MINIO_ROOT_PASSWORD=<forte>  MINIO_BUCKET=institutoipi-media
#   # NÃO setar UPLOADTHING_TOKEN → usa o MinIO local do servidor
#
#   # Email: Resend
#   EMAIL_FROM=contato@institutoipi.org
#   EMAIL_SMTP_HOST=smtp.resend.com   EMAIL_SMTP_PORT=465   EMAIL_SMTP_SECURE=true
#   EMAIL_SMTP_USER=resend            EMAIL_SMTP_PASSWORD=<resend api key>
#   LEAD_NOTIFY_TO=contato@institutoipi.org
# ============================================================================