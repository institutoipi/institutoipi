# Instituto IPI — variáveis de ambiente
# Copie para .env e preencha com valores reais.
#
# Produção: as vars ficam no painel da Vercel (Project → Settings → Environment
# Variables). O stack é Vercel (app) + Neon (Postgres) + Cloudflare R2 (mídia) +
# Resend (email). As migrations rodam no build (ver vercel.json), não no boot.
#
#   PAYLOAD_PUBLIC_URL = https://institutoipi.org
#   SITE_URL           = https://institutoipi.org
#   DATABASE_URL       = connection string do Neon (usar a "direct" p/ migrations no build)
#
#   # Cloudflare R2 (bucket com acesso público habilitado) — reaproveita as vars MINIO_*:
#   MINIO_ENDPOINT     = <accountid>.r2.cloudflarestorage.com
#   MINIO_PORT         = 443
#   MINIO_USE_SSL      = true
#   MINIO_ROOT_USER    = R2 Access Key ID
#   MINIO_ROOT_PASSWORD= R2 Secret Access Key
#   MINIO_BUCKET       = institutoipi-media
#   MINIO_PUBLIC_URL   = URL pública do bucket R2 (pub-xxxx.r2.dev ou custom domain)
#
#   # Resend (SMTP):
#   EMAIL_SMTP_HOST=smtp.resend.com  EMAIL_SMTP_PORT=465  EMAIL_SMTP_SECURE=true
#   EMAIL_SMTP_USER=resend           EMAIL_SMTP_PASSWORD=<resend-api-key>

# --- Postgres ---
POSTGRES_DB=institutoipi
POSTGRES_USER=institutoipi
POSTGRES_PASSWORD=changeme
POSTGRES_PORT=5432

# --- Payload / Next.js ---
CMS_PORT=3000
PAYLOAD_SECRET=troque-por-uma-string-longa-e-aleatoria
DATABASE_URL=postgresql://institutoipi:changeme@localhost:5432/institutoipi
PAYLOAD_PUBLIC_URL=http://localhost:3000

# SITE_URL: origem pública do site (CORS/CSRF); default https://institutoipi.org
SITE_URL=https://institutoipi.org

# --- Mailpit (dev) ---
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_PORT=8025

# --- Email (SMTP) ---
EMAIL_FROM=contato@institutoipi.org
EMAIL_SMTP_HOST=localhost
EMAIL_SMTP_PORT=1025
EMAIL_SMTP_USER=dev
EMAIL_SMTP_PASSWORD=dev
EMAIL_SMTP_SECURE=false
LEAD_NOTIFY_TO=contato@institutoipi.org

# --- MinIO (armazenamento S3-compatible) ---
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin123
MINIO_BUCKET=institutoipi-media
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_USE_SSL=false
MINIO_PUBLIC_URL=http://localhost:9000
